# ---- Database ----
DATABASE_URL="postgresql://portal:portal@localhost:5432/portal?schema=public"

# ---- Server ----
PORT=4000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# ---- Auth ----
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# ---- Stripe ----
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_CURRENCY=usd

# ---- Email (Nodemailer SMTP) ----
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=
SMTP_PASS=
MAIL_FROM="Training Institute <no-reply@institute.test>"

# ---- SMS (stubbed) ----
SMS_ENABLED=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# ---- Uploads ----
UPLOAD_DIR=./uploads
PUBLIC_URL=http://localhost:4000

# ---- Cron ----
ENABLE_CRON=true

# ---- Client (Vite) ----
VITE_API_URL=http://localhost:4000/api
